{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "checkrd-policy",
  "title": "Checkrd Policy File",
  "description": "Schema for checkrd.yaml policy files.",
  "type": "object",
  "required": ["default", "rules"],
  "properties": {
    "default": { "type": "string", "enum": ["allow", "deny"] },
    "mode": {
      "type": "string",
      "enum": ["enforce", "dry_run"],
      "default": "enforce",
      "description": "Enforcement mode. dry_run logs decisions but always allows (shadow testing)."
    },
    "rules": {
      "type": "array",
      "maxItems": 200,
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string", "minLength": 1, "maxLength": 128 },
          "allow": { "$ref": "#/$defs/matcher" },
          "deny": { "$ref": "#/$defs/matcher" },
          "limit": { "$ref": "#/$defs/rate_limit" },
          "source": {
            "type": "string",
            "description": "Source of rule after merge: org, agent, or template:<name>. Set by control plane, not user-authored."
          }
        }
      }
    }
  },
  "$defs": {
    "matcher": {
      "type": "object",
      "properties": {
        "method": {
          "type": "array",
          "items": { "type": "string", "enum": ["GET", "POST", "PUT", "PATCH", "DELETE", "HEAD", "OPTIONS"] }
        },
        "url": {
          "type": "string",
          "maxLength": 1024,
          "description": "URL glob pattern. * matches one segment, ** matches zero or more segments (gitignore-style)."
        },
        "body": {
          "oneOf": [
            { "$ref": "#/$defs/body_matcher" },
            { "type": "array", "items": { "$ref": "#/$defs/body_matcher" } }
          ]
        },
        "headers": {
          "type": "array",
          "items": { "$ref": "#/$defs/header_matcher" }
        },
        "time_outside": {
          "type": "string",
          "pattern": "^[0-9]{2}:[0-9]{2}-[0-9]{2}:[0-9]{2}$"
        },
        "timezone": { "type": "string" }
      }
    },
    "body_matcher": {
      "type": "object",
      "required": ["jsonpath"],
      "properties": {
        "jsonpath": { "type": "string", "minLength": 1, "maxLength": 256 },
        "exact": {},
        "in": { "type": "array", "minItems": 1 },
        "min": { "type": "integer" },
        "max": { "type": "integer" },
        "prefix": { "type": "string", "maxLength": 256 },
        "suffix": { "type": "string", "maxLength": 256 },
        "contains": { "type": "string", "maxLength": 256 },
        "regex": { "type": "string", "maxLength": 256 }
      }
    },
    "header_matcher": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 128 },
        "exact": { "type": "string" },
        "prefix": { "type": "string" },
        "suffix": { "type": "string" },
        "contains": { "type": "string" },
        "regex": { "type": "string", "maxLength": 256 },
        "present": { "type": "boolean" }
      }
    },
    "rate_limit": {
      "type": "object",
      "required": ["calls_per_minute", "per"],
      "properties": {
        "calls_per_minute": { "type": "integer", "minimum": 1 },
        "per": { "type": "string", "enum": ["endpoint", "global", "body_field"] },
        "field": { "type": "string", "maxLength": 256 }
      },
      "if": { "properties": { "per": { "const": "body_field" } } },
      "then": { "required": ["field"] }
    }
  }
}
