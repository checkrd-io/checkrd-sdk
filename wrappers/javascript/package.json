{
  "name": "checkrd",
  "version": "0.3.1",
  "description": "Policy enforcement, kill switch, and telemetry for AI agent API calls. Intercepts fetch(), evaluates against a signed policy in a WASM sandbox, and emits signed telemetry.",
  "keywords": [
    "ai",
    "agents",
    "policy",
    "security",
    "observability",
    "openai",
    "anthropic",
    "llm",
    "proxy",
    "kill-switch"
  ],
  "license": "Apache-2.0",
  "author": "Checkrd <support@checkrd.io>",
  "homepage": "https://checkrd.io",
  "bugs": "https://github.com/checkrd-io/checkrd-sdk/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/checkrd-io/checkrd-sdk.git",
    "directory": "wrappers/javascript"
