  "sideEffects": false,
  "scripts": {
    "build": "tsup && npm run build:downlevel-dts",
    "build:downlevel-dts": "downlevel-dts dist dist/types-ts3.8 --to=3.8",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "audit:deps": "npm audit --omit=dev --audit-level=high",
    "publint": "publint --strict",
    "attw": "attw --pack . --profile node16 --ignore-rules=cjs-resolves-to-esm",
    "sbom": "cyclonedx-npm --output-file artifacts/sbom.json --omit dev",
    "pack:smoke": "node scripts/install-sanity.mjs",
    "size": "size-limit",
    "ci": "npm run typecheck && npm run lint && npm run test:coverage && npm run build && npm run publint && npm run attw && npm run size"
  },
  "size-limit": [
